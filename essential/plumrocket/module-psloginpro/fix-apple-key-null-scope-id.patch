Fixes null scope_id when saving Apple key file config. The original code compared
$this->getScope() (which returns plural forms: "stores", "websites") against singular
ScopeInterface constants ("store", "website"), so the ternary always resolved to null.
On strict MySQL this causes: SQLSTATE[23000] Column 'scope_id' cannot be null.
Fix: use $this->getScopeId() which is always correctly set by Magento for all scopes.

diff --git a/Model/Config/Backend/File/Apple/Key.php b/Model/Config/Backend/File/Apple/Key.php
--- a/Model/Config/Backend/File/Apple/Key.php
+++ b/Model/Config/Backend/File/Apple/Key.php
@@ -137,13 +137,19 @@
     {
         $this->_dataSaveAllowed = false;
         $scope = $this->getScope() ?: ScopeConfigInterface::SCOPE_TYPE_DEFAULT;
-        $scopeCode = $scope === ScopeInterface::SCOPE_STORE
-            ? $this->getStore()
-            : ($scope === ScopeInterface::SCOPE_WEBSITE ? $this->getWebsite() : null);
+        // BEGIN PATCH
+        // $scopeCode = $scope === ScopeInterface::SCOPE_STORE
+        //     ? $this->getStore()
+        //     : ($scope === ScopeInterface::SCOPE_WEBSITE ? $this->getWebsite() : null);
+        $scopeId = (int) $this->getScopeId();
+        // END PATCH

         $value = $this->getValue();
         if (!empty($value['delete'])) {
-            $this->configWriter->delete('psloginpro/apple/key_file_content', $scope, $scopeCode);
+            // BEGIN PATCH
+            // $this->configWriter->delete('psloginpro/apple/key_file_content', $scope, $scopeCode);
+            $this->configWriter->delete('psloginpro/apple/key_file_content', $scope, $scopeId);
+            // END PATCH
             return $this;
         }

@@ -160,7 +166,10 @@
             }

             $encryptedKey = $this->encryptor->encrypt($keyContent);
-            $this->configWriter->save('psloginpro/apple/key_file_content', $encryptedKey, $scope, $scopeCode);
+            // BEGIN PATCH
+            // $this->configWriter->save('psloginpro/apple/key_file_content', $encryptedKey, $scope, $scopeCode);
+            $this->configWriter->save('psloginpro/apple/key_file_content', $encryptedKey, $scope, $scopeId);
+            // END PATCH
         }

         if ($keyResource) {
