+                // 'onclick' => 'setLocation(\''.$this->getUrl('pslogin/integration/regenerateAppleSecretKey').'\')',
+                'onclick' => 'setLocation(\''.$this->getUrl('pslogin/integration/regenerateAppleSecretKey', $this->getRegenerateUrlParams()).'\')',
