@@ -49,9 +49,25 @@ class RegenerateButton extends Field
             [
                 'id'      => 'regenerate_apple_secret_button',
                 'label'   => __('Regenerate'),
-                'onclick' => 'setLocation(\''.$this->getUrl('pslogin/integration/regenerateAppleSecretKey').'\')',
