+
+    // BEGIN PATCH
+    private function getRegenerateUrlParams(): array
+    {
+        $params = [];
+        if ($storeId = $this->getRequest()->getParam('store')) {
+            $params['store'] = $storeId;
+        } elseif ($websiteId = $this->getRequest()->getParam('website')) {
+            $params['website'] = $websiteId;
+        }
+        return $params;
+    }
+    // END PATCH
 }
