+    protected function invertEavSubqueryToIncludeUnsetAttributes(
+        \Magento\Catalog\Model\ResourceModel\Product\Collection $collection
+    ): void {
+        $select = $collection->getSelect();
+        $whereParts = $select->getPart(\Magento\Framework\DB\Select::WHERE);
+
+        if (empty($whereParts)) {
+            return;
+        }
+
+        $modifiedParts = array_map(
+            fn (string $part): string => $this->invertEavNotLikeCondition($this->invertEavNotInCondition($part)),
+            $whereParts
+        );
+
+        $select->setPart(\Magento\Framework\DB\Select::WHERE, $modifiedParts);
+    }
+
+    protected function invertEavNotInCondition(string $part): string
+    {
+        return (string) preg_replace(
+            '/(e\.entity_id) IN\((\(SELECT .+? WHERE \(.+?\) AND) \((ca_\w+\.value) NOT IN(\([^)]+\))\)\)\)/s',
+            '$1 NOT IN($2 ($3 IN $4)))',
+            $part
+        );
+    }
+
+    protected function invertEavNotLikeCondition(string $part): string
+    {
+        return (string) preg_replace(
+            "/(e\.entity_id) IN\((\(SELECT .+? WHERE \(.+?\) AND) \((ca_\w+\.value) NOT LIKE ('[^']+')\)\)\)/s",
+            '$1 NOT IN($2 ($3 LIKE $4)))',
+            $part
+        );
+    }
+
