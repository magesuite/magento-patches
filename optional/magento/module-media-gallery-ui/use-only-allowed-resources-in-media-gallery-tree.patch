+    /**
+     * Yield sub-directory paths lazily (pre-order: a parent is always emitted before its children)
+     *
+     * @param ReadInterface $mediaDirectory
+     * @param ReadInterface $imageDirectory
+     * @param string|null $path
+     * @return \Traversable
+     */
+    private function getSubDirectories(
+        ReadInterface $mediaDirectory,
+        ReadInterface $imageDirectory,
+        ?string $path = null
+    ): \Traversable {
+        foreach ($imageDirectory->read($path) as $itemPath) {
+            if (!$imageDirectory->isDirectory($itemPath)) {
+                continue;
+            }
+            yield $mediaDirectory->getRelativePath($imageDirectory->getAbsolutePath($itemPath));
+            yield from $this->getSubDirectories($mediaDirectory, $imageDirectory, $itemPath);
+        }
+    }
