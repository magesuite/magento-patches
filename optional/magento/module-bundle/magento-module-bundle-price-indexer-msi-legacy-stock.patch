+    // PATCH START
+    protected function applyDynamicBundleSelectionStockSalabilityFilter(Select $select, array $dimensions): void
+    {
+        $assignedStockId = $this->resolveWebsiteAssignedStockIdFromDimensions($dimensions);
+        if ($assignedStockId === null) {
+            try {
+                $mapped = $this->getAssignedStockIdForWebsite->execute($this->websiteRepository->getDefault()->getCode());
+                if ($mapped !== null) {
+                    $assignedStockId = (int)$mapped;
+                }
+            } catch (\Exception $e) {
+                $assignedStockId = null;
+            }
+        }
+        if ($assignedStockId === null) {
+            $assignedStockId = (int)$this->defaultStockProvider->getId();
+        }
+        $this->applySalabilityFilterForStockId($select, $assignedStockId);
+    }
+
+    private function resolveWebsiteAssignedStockIdFromDimensions(array $dimensions): ?int
+    {
+        foreach ($dimensions as $dimension) {
+            if ($dimension->getName() !== WebsiteDimensionProvider::DIMENSION_NAME || !$dimension->getValue()) {
+                continue;
+            }
+            $websiteId = (int)$dimension->getValue();
+            try {
+                $website = $this->websiteRepository->getById($websiteId);
+                $stockId = $this->getAssignedStockIdForWebsite->execute($website->getCode());
+            } catch (\Exception $e) {
+                return null;
+            }
+
+            return $stockId;
+        }
+
+        return null;
+    }
+
+    protected function applySalabilityFilterForStockId(Select $select, int $stockId): void
+    {
+        if ($stockId === (int)$this->defaultStockProvider->getId()) {
+            $joinConditions = [
+                'dyn_bundle_stock_si.product_id = bs.product_id',
+                'dyn_bundle_stock_si.website_id = i.website_id',
+                'dyn_bundle_stock_si.stock_id = ' . $stockId,
+            ];
+            $select->join(
+                ['dyn_bundle_stock_si' => $this->getTable('cataloginventory_stock_status')],
+                implode(' AND ', $joinConditions),
+                []
+            )->where('dyn_bundle_stock_si.stock_status = ?', Stock::STOCK_IN_STOCK);
+
+            return;
+        }
+
+        $msiTable = $this->stockIndexTableNameResolver->execute($stockId);
+
+        $select->join(
+            ['selection_child_cpe' => $this->getTable('catalog_product_entity')],
+            'selection_child_cpe.entity_id = bs.product_id',
+            []
+        )->join(
+            ['msi_stock' => $msiTable],
+            'msi_stock.sku = selection_child_cpe.sku',
+            []
+        )->where('msi_stock.is_salable = ?', 1);
+    }
+
+    protected function synchronizeBundleSelectionLegacyStockStatusFromMsi(array $dimensions, array $parentEntityIds): void
+    {
+        $connection = $this->resource->getConnection();
+        $processedStockIds = [];
+        foreach ($this->resolveWebsiteIdsForBundleStockSync($dimensions) as $websiteId) {
+            try {
+                $website = $this->websiteRepository->getById($websiteId);
+                $stockId = $this->getAssignedStockIdForWebsite->execute($website->getCode());
+            } catch (\Exception $e) {
+                continue;
+            }
+
+            if ($stockId === null || $stockId == $this->defaultStockProvider->getId()) {
+                continue;
+            }
+
+            if (isset($processedStockIds[$stockId])) {
+                continue;
+            }
+
+            $msiTable = $this->stockIndexTableNameResolver->execute($stockId);
+
+            $processedStockIds[$stockId] = true;
+            $this->applyBundleChildLegacyStockAggregateUpdateFromMsi($connection, $msiTable, $parentEntityIds);
+        }
+    }
+
+    protected function applyBundleChildLegacyStockAggregateUpdateFromMsi(
+        \Magento\Framework\DB\Adapter\AdapterInterface $connection,
+        string $msiIndexTable,
+        array $parentEntityIds
+    ): void {
+        $metadata = $this->metadataPool->getMetadata(ProductInterface::class);
+        $linkField = $metadata->getLinkField();
+
+        $productTable = $this->resource->getTableName('catalog_product_entity');
+        $bundleSelectionTable = $this->resource->getTableName('catalog_product_bundle_selection');
+        $stockStatusTable = $this->resource->getTableName('cataloginventory_stock_status');
+
+        $subSelect = $connection->select()
+            ->from(['msi' => $msiIndexTable], [])
+            ->join(
+                ['cpe' => $productTable],
+                'cpe.sku = msi.sku',
+                []
+            )
+            ->join(
+                ['bsel' => $bundleSelectionTable],
+                'bsel.product_id = cpe.entity_id',
+                []
+            )
+            ->join(
+                ['parent' => $productTable],
+                'parent.' . $linkField . ' = bsel.parent_product_id AND parent.type_id = ' . $connection->quote(
+                    \Magento\Catalog\Model\Product\Type::TYPE_BUNDLE
+                ),
+                []
+            );
+
+        if ($parentEntityIds !== []) {
+            $subSelect->where('parent.entity_id IN (?)', $parentEntityIds);
+        }
+
+        $subSelect->columns(
+            [
+                'product_id' => 'cpe.entity_id',
+                'stock_status' => new \Zend_Db_Expr('MAX(msi.is_salable)'),
+                'qty' => new \Zend_Db_Expr('MAX(msi.quantity)'),
+            ]
+        )->group('cpe.entity_id');
+
+        $updateSelect = $connection->select()
+            ->joinInner(
+                ['sync' => $subSelect],
+                'sync.product_id = css.product_id',
+                []
+            )->columns(
+                ['stock_status', 'qty'],
+                'sync'
+            );
+
+        $query = $updateSelect->crossUpdateFromSelect(['css' => $stockStatusTable]);
+        $connection->query($query);
+    }
+    // PATCH END
+
